{
  "name": "Vetur Plus",
  "version": "5.3.4",
  "version_name": "5.3.4",
  "description": "Vetur, but better. A customized Vue Devtools v5 fork for an improved Vue development experience.",
  "manifest_version": 3,
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/16-gray.png",
      "48": "icons/48-gray.png",
      "128": "icons/128-gray.png"
    },
    "default_title": "Vetur Plus",
    "default_popup": "popups/not-found.html"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "devtools.html",
        "devtools-background.html",
        "offscreen.html",
        "build/backend.js",
        "build/proxy.js",
        "build/hook-exec.js",
        "build/detector-exec.js",
        "build/keep-alive.js",
        "build/offscreen.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ],
  "devtools_page": "devtools-background.html",
  "background": {
    "service_worker": "build/service-worker.js"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "permissions": [
    "storage",
    "scripting",
    "alarms",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "build/hook-exec.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "build/detector.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
